# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=meta/llama-3.1-70b-instruct

# Server Configuration
PORT=5000

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id

# CORS Configuration - Add your frontend URL here
# For development: http://localhost:5173
# For production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,https://aistartupidea-seven.vercel.app

# Rate Limiting (optional)
RATELIMIT_WINDOW_MS=60000
RATELIMIT_MAX=100

# Dodo Payments (https://app.dodopayments.com → Developer → API Keys)
DODO_API_KEY=your_dodo_api_key_here
DODO_WEBHOOK_SECRET=whsec_your_webhook_secret_here
DODO_PRO_PRODUCT_ID=pdt_your_pro_product_id
DODO_FOUNDER_PRODUCT_ID=pdt_your_founder_product_id
FRONTEND_URL=https://your-app.vercel.app