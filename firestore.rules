rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - authenticated users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Business ideas - authenticated users can read/write their own ideas
    match /business_ideas/{ideaId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null;
      // Allow backend (admin SDK) to write without auth (handled server-side)
    }
  }
}
